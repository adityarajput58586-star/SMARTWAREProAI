# SmartWare Pro - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Email Configuration (for notifications)
# ============================================

# Your email address (Gmail recommended)
EMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# Get it from: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your-app-password-here

# SMTP Server (default: Gmail)
SMTP_SERVER=smtp.gmail.com

# SMTP Port (default: 587 for TLS)
SMTP_PORT=587

# ============================================
# Database Configuration (optional)
# ============================================

# Leave empty to use SQLite (default)
# Or set to PostgreSQL connection string for cloud database
# DATABASE_URL=postgresql://user:password@host/database

# ============================================
# Application Configuration (optional)
# ============================================

# Secret key for sessions (auto-generated if not set)
# SESSION_SECRET=your-secret-key-here

# Debug mode (set to False in production)
# DEBUG=True
